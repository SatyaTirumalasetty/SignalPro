# ═══════════════════════════════════════════════════════════════
# PHASE 1: Essential Configuration
# ═══════════════════════════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=signalpro_prod
DB_USER=signalpro_admin
DB_PASSWORD=your_secure_password_here_min_20_chars
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis (for caching & rate limiting)
REDIS_URL=redis://localhost:6379/0

# Frontend URL (CORS)
FRONTEND_URL=https://app.signalpro.com
# Public URL of this API server (used to build OAuth callback URLs)
API_BASE_URL=https://api.signalpro.com

# ═══════════════════════════════════════════════════════════════
# PHASE 2: Security & Authentication
# ═══════════════════════════════════════════════════════════════

# JWT Configuration
JWT_SECRET=your_64_char_random_jwt_secret_key_change_this_immediately!
JWT_REFRESH_SECRET=your_64_char_random_refresh_secret_also_change_me!
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Encryption (AES-256-GCM, random IV per value — see config/brokerEncryption.js)
ENCRYPTION_KEY=your_32_char_base64_encrypted_key_here_change_me

# API Key Hashing
API_KEY_PREFIX=sp_live_
API_KEY_LENGTH=32

# ═══════════════════════════════════════════════════════════════
# PHASE 3: AI & Trading
# ═══════════════════════════════════════════════════════════════

# Anthropic Claude AI
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=1000

# Market Data (choose one or use multiple for fallback)
YAHOO_FINANCE_API=https://query1.finance.yahoo.com
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
POLYGON_API_KEY=your_polygon_key

# Alpaca Market Data (app-level keys — separate from per-user broker connections)
# Used for live quote streaming and news-enriched AI signals
ALPACA_API_KEY=your_alpaca_data_api_key
ALPACA_API_SECRET=your_alpaca_data_api_secret
ALPACA_DATA_FEED=iex
LIVE_PRICE_POLL_MS=5000

# NSE India Market Data (for Indian stocks)
NSE_API_URL=https://api.example.com

# ═══════════════════════════════════════════════════════════════
# PHASE 4: Payment & Billing
# ═══════════════════════════════════════════════════════════════

# Stripe (Primary Payment Gateway)
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay (For India)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# PayPal (Optional)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret

# ═══════════════════════════════════════════════════════════════
# PHASE 5: Admin & Notifications
# ═══════════════════════════════════════════════════════════════

# Email Service (SendGrid or similar)
SENDGRID_API_KEY=your_sendgrid_key
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_key
FROM_EMAIL=noreply@signalpro.com

# Webhook secrets for broker event verification
ALPACA_WEBHOOK_SECRET=your_alpaca_webhook_secret
COINBASE_WEBHOOK_SECRET=your_coinbase_webhook_secret

# Slack Notifications (for admin alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts

# ═══════════════════════════════════════════════════════════════
# PHASE 6: Monitoring & Logging
# ═══════════════════════════════════════════════════════════════

# Sentry (Error tracking)
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# AWS S3 (for document storage, backups)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=signalpro-prod
AWS_S3_BACKUP_BUCKET=signalpro-backups

# DataDog (optional, for monitoring)
DATADOG_API_KEY=your_datadog_key

# ═══════════════════════════════════════════════════════════════
# Secrets Management (production)
# ═══════════════════════════════════════════════════════════════

# If set, src/index.js fetches this secret (a flat JSON object of
# key/value pairs) from AWS Secrets Manager at startup and merges it into
# process.env before any other config is read. Values already set in the
# environment take precedence, so this only fills in what's missing.
# Leave unset for local development — secrets come from this .env file.
AWS_SECRETS_MANAGER_SECRET_ID=
# AWS_REGION is also used above for S3

# ═══════════════════════════════════════════════════════════════
# Feature Flags & Rate Limiting
# ═══════════════════════════════════════════════════════════════

# Global rate limits
RATE_LIMIT_WINDOW_MS=60000
MAX_REQUESTS_PER_MINUTE=120
MAX_AI_REQUESTS_PER_MINUTE=10
MAX_TRADES_PER_MINUTE=5

# Feature toggles
FEATURE_AI_ANALYSIS=true
FEATURE_WEBHOOK_ALERTS=true
FEATURE_SOCIAL_TRADING=false
FEATURE_PAPER_TRADING=true
FEATURE_ADVANCED_ANALYTICS=false

# Broker credentials (stored encrypted in DB, not here)
# These are examples - actual credentials come from user setup
ZERODHA_DEMO_API_KEY=demo_key
MOOMOO_DEMO_API_KEY=demo_key
