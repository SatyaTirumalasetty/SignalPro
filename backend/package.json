{
  "name": "signalpro-backend",
  "version": "1.0.0",
  "description": "SignalPro Enterprise - Secure AI Trading Platform Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js --ignore logs/",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "gen:indicator-fixtures": "node scripts/genIndicatorFixtures.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@aws-sdk/client-secrets-manager": "^3.1068.0",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "pg": "^8.11.3",
    "pg-promise": "^11.5.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.2.0",
    "razorpay": "^2.9.6",
    "redis": "^4.6.14",
    "stripe": "^14.18.0",
    "uuid": "^11.1.1",
    "ws": "^8.16.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/src/__tests__/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/__tests__/**"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testTimeout": 15000
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3"
  }
}
