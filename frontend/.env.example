VITE_API_BASE_URL=http://localhost:3001

# Browser-reachable URLs for the federated remotes' remoteEntry.js — the shell
# loads these client-side, so they must resolve from the user's browser, not
# just from inside the build container.
VITE_TRADING_REMOTE_URL=http://localhost:5174/remoteEntry.js
VITE_MARKET_REMOTE_URL=http://localhost:5175/remoteEntry.js
VITE_ADMIN_REMOTE_URL=http://localhost:5176/remoteEntry.js
