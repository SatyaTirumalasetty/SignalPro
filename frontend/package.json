{
  "name": "signalpro-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "shell",
    "remotes/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:shell": "npm run dev --workspace=shell",
    "dev:trading": "npm run dev --workspace=trading_remote",
    "dev:market": "npm run dev --workspace=market_remote",
    "dev:admin": "npm run dev --workspace=admin_remote",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
